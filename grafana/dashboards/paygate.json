{
  "title": "PayGate Observability",
  "panels": [
    {
      "title": "HTTP Error Rates (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(app_error_rates_total[1m])",
          "legendFormat": "{{component}}"
        }
      ]
    },
    {
      "title": "HTTP Request Latency (P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "title": "Webhook & Retry Queue Depth",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "failed_payment_retry_queue_depth",
          "legendFormat": "Depth"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 10, "color": "orange" },
              { "value": 50, "color": "red" }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 38,
  "timezone": "browser",
  "refresh": "5s"
}
